{
  "title": "Data Ingestion Service",
  "uid": "data-ingestion-service",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "topic",
        "label": "raw_candles",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(kafka_messages_produced_total, topic)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "handler",
        "label": "HTTP Handler",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_requests_total, handler)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "refresh": 2,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "type": "row",
      "title": "HTTP — Общее состояние сервиса",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "title": "RPS по эндпоинтам",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{handler=~\"$handler\"}[1m])) by (handler, method)",
          "legendFormat": "{{method}} {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 2,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{handler=~\"$handler\"}[2m])) by (le, handler))",
          "legendFormat": "P50 {{handler}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{handler=~\"$handler\"}[2m])) by (le, handler))",
          "legendFormat": "P95 {{handler}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{handler=~\"$handler\"}[2m])) by (le, handler))",
          "legendFormat": "P99 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "HTTP Error Rate (4xx + 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 1, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"4..\", handler=~\"$handler\"}[1m])) by (handler) / sum(rate(http_requests_total{handler=~\"$handler\"}[1m])) by (handler)",
          "legendFormat": "4xx {{handler}}"
        },
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\", handler=~\"$handler\"}[1m])) by (handler) / sum(rate(http_requests_total{handler=~\"$handler\"}[1m])) by (handler)",
          "legendFormat": "5xx {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          },
          "custom": { "lineWidth": 2, "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "HTTP — Stat cards",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 9, "w": 24, "h": 1 }
    },
    {
      "id": 4,
      "title": "Текущий RPS (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(http_requests_total[1m]))", "legendFormat": "RPS" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [ { "color": "blue", "value": null } ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "title": "P95 Latency (all)",
      "type": "stat",
      "gridPos": { "x": 4, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[2m])) by (le))",
          "legendFormat": "P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "title": "5xx Error Rate",
      "type": "stat",
      "gridPos": { "x": 8, "y": 10, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m]))",
          "legendFormat": "5xx rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 200,
      "type": "row",
      "title": "Kafka Producer — Throughput",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 }
    },
    {
      "id": 20,
      "title": "Сообщений/сек по топикам",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 15, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_messages_produced_total{topic=~\"$topic\"}[1m])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msgps",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi" } }
    },
    {
      "id": 22,
      "title": "Всего сообщений отправлено (за выбранный период)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(kafka_messages_produced_total{topic=~\"$topic\"}[$__range])",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 24,
      "title": "Produce Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 23, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(kafka_produce_duration_seconds_bucket{topic=~\"$topic\"}[2m])) by (le, topic))",
          "legendFormat": "P50 {{topic}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(kafka_produce_duration_seconds_bucket{topic=~\"$topic\"}[2m])) by (le, topic))",
          "legendFormat": "P95 {{topic}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(kafka_produce_duration_seconds_bucket{topic=~\"$topic\"}[2m])) by (le, topic))",
          "legendFormat": "P99 {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    },
    {
      "id": 300,
      "type": "row",
      "title": "Kafka Producer — Ошибки и надёжность",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 31, "w": 24, "h": 1 }
    },
    {
      "id": 34,
      "title": "Stat — Сообщений за час",
      "type": "stat",
      "gridPos": { "x": 0, "y": 32, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(kafka_messages_produced_total{topic=~\"$topic\"}[1h]))",
          "legendFormat": "Messages/h"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 500,
      "type": "row",
      "title": "Бизнес-метрики",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 36, "w": 24, "h": 1 }
    },
    {
      "id": 50,
      "title": "Сообщений по топикам (breakdown)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(kafka_messages_produced_total{topic=~\"$topic\"}[$__range])) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } },
      "options": { "pieType": "donut", "tooltip": { "mode": "multi" } }
    },
    {
      "id": 51,
      "title": "Сообщений/сек по статусу (success / error)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_messages_produced_total{topic=~\"$topic\", status=\"success\"}[1m])) by (topic)",
          "legendFormat": "success {{topic}}"
        },
        {
          "expr": "sum(rate(kafka_produce_errors_total{topic=~\"$topic\"}[1m])) by (topic)",
          "legendFormat": "error {{topic}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "msgps",
          "custom": { "lineWidth": 2 }
        },
        "overrides": [
          {
            "matcher": { "id": "byRegexp", "options": "^error.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "^success.*" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }
            ]
          }
        ]
      }
    },
    {
      "id": 52,
      "title": "Heatmap — распределение produce latency",
      "type": "heatmap",
      "gridPos": { "x": 16, "y": 37, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(kafka_produce_duration_seconds_bucket{topic=~\"$topic\"}[2m])) by (le)",
          "legendFormat": "{{le}}",
          "format": "heatmap"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } },
      "options": {
        "yAxis": { "unit": "s" },
        "color": { "scheme": "Oranges", "mode": "scheme" }
      }
    }
  ]
}